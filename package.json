{
	"name": "easter-date",
	"version": "1.1.2",
	"author": "Roman Ožana <roman@ozana.cz> (https://ozana.cz)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/OzzyCzech/easter-date.git"
	},
	"license": "MIT",
	"description": "Calculate the date of Easter for a given year",
	"keywords": [
		"easter",
		"date",
		"calendar",
		"holly week"
	],
	"type": "module",
	"exports": {
		"types": "./dist/index.d.ts",
		"default": "./dist/index.js"
	},
	"scripts": {
		"build": "rm -rf dist && tsc",
		"release": "npx np",
		"prepare": "npm run build",
		"test": "tsc --noEmit && vitest",
		"format": "biome check --write .",
		"format:check": "biome check .",
		"docs": "typedoc"
	},
	"engines": {
		"node": ">=20"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@ozzyczech/tsconfig": "^1.0.0",
		"@types/node": "^25.6.0",
		"np": "^11.0.3",
		"tsx": "^4.21.0",
		"typedoc": "^0.28.18",
		"typescript": "^6.0.2",
		"vitest": "^4.1.4"
	}
}
